{
  "name": "peptide-vendor-directory",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx --env-file=.env src/db/seed.ts",
    "db:seed:studies": "tsx --env-file=.env src/db/seed-compound-studies.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@content-collections/core": "^0.15.0",
    "@content-collections/mdx": "^0.2.2",
    "@content-collections/vite": "^0.3.0",
    "@mdx-js/rollup": "^3.1.1",
    "@tanstack/react-router": "^1.168.7",
    "@tanstack/react-start": "^1.167.12",
    "@tanstack/zod-adapter": "^1.166.9",
    "better-auth": "^1.2.12",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "resend": "^6.9.4",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "overrides": {
      "better-call": "1.0.29"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "nitro": "^3.0.260311-beta",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0"
  }
}
